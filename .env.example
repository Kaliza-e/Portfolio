# Site URL (used in sitemap, robots, Open Graph)
#NEXT_PUBLIC_SITE_URL=https://kaliza.dev

# Get your API key from https://resend.com (free tier: 100 emails/day)
# REQUIRED on Vercel: Project Settings → Environment Variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Your email address — contact form messages will be sent here
CONTACT_EMAIL=kalizaesther5@gmail.com

# Verified sender in Resend (required for production on kaliza.dev)
# 1. Add domain at https://resend.com/domains
# 2. Set this to e.g. Kaliza Portfolio <contact@kaliza.dev>
RESEND_FROM_EMAIL=

# Upstash Redis — distributed rate limiting for /api/contact (recommended for production)
# Create a free database at https://upstash.com
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx